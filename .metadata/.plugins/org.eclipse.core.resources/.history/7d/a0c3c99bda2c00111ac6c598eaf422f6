spring:
  application:
    name: api-gateway

  cloud:
    gateway:
      # -----------------------------------------------
      # Global CORS
      # -----------------------------------------------
      globalcors:
        corsConfigurations:
          '[/**]':
            allowedOrigins:
              - "http://localhost:3000"
              - "http://localhost:4000"
            allowedMethods: ["*"]
            allowedHeaders: ["*"]
            exposedHeaders: ["Authorization"]
            allowCredentials: true

      # -----------------------------------------------
      # Routes
      # lb:// prefix uses Eureka to resolve service names
      # -----------------------------------------------
      routes:

        # Auth — public, no JWT filter
        - id: auth-service
          uri: lb://AUTH-SERVICE
          predicates:
            - Path=/auth/**

        # User — protected
        - id: user-service
          uri: lb://USER-SERVICE
          predicates:
            - Path=/api/users/**
          filters:
            - name: JwtAuthFilter

        # Twit — protected
        - id: twit-service
          uri: lb://TWIT-SERVICE
          predicates:
            - Path=/api/twits/**
          filters:
            - name: JwtAuthFilter

        # Like — protected
        - id: like-service
          uri: lb://LIKE-SERVICE
          predicates:
            - Path=/api/likes/**
          filters:
            - name: JwtAuthFilter

        # Payment — protected
        - id: payment-service-subscribe
          uri: lb://PAYMENT-SERVICE
          predicates:
            - Path=/api/payment/subscribe/**
          filters:
            - name: JwtAuthFilter

        # Payment verify callback — public (called by Razorpay redirect)
        - id: payment-service-verify
          uri: lb://PAYMENT-SERVICE
          predicates:
            - Path=/api/payment/verify

        # Block all /internal/** — never forwarded externally
        - id: block-internal
          uri: lb://USER-SERVICE
          predicates:
            - Path=/internal/**
          filters:
            - name: BlockInternalFilter

server:
  port: 8080

# -----------------------------------------------
# Eureka
# -----------------------------------------------
eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/
    register-with-eureka: true
    fetch-registry: true
  instance:
    prefer-ip-address: true

